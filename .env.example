# ─────────────────────────────────────────────
#  Hi-Tech AI Sales Org — Environment Config
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# App
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Database (SQLite — path to the .db file)
DATABASE_URL=sqlite+aiosqlite:///./hitech_sales.db

# ── Claude API (Anthropic) ───────────────────
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── WhatsApp Meta Cloud API ──────────────────
# Get from Meta Business Developer Console
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=EAAB...
WHATSAPP_VERIFY_TOKEN=hitech-verify-2026
WHATSAPP_API_VERSION=v20.0

# ── CRM (rustx.net) ─────────────────────────
CRM_BASE_URL=https://api-crm.rustx.net
CRM_TOKEN=                          # Bearer token from /api/Authentication/dologin
CRM_USERNAME=                       # Login username for auto-token refresh
CRM_PASSWORD=                       # Login password for auto-token refresh
CRM_POLL_INTERVAL_MINUTES=30        # How often to poll for new comments

# ── Gmail API (optional — writing style) ────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback

# ── Mukul (owner config) ─────────────────────
MUKUL_PHONE=919XXXXXXXXX            # Mukul's WhatsApp number (with country code, no +)
MUKUL_NAME=Mukul Sareen

# ── Escalation Rules ─────────────────────────
AI_CONFIDENCE_THRESHOLD=88          # % — below this score triggers escalation
SENIOR_ESCALATION_WINDOW_HOURS=24   # Hours senior has before it bumps to Mukul
PRICING_AUTHORITY_PCT=8             # Max % discount reps can offer without approval
KEY_ACCOUNT_LTV_THRESHOLD=2000000   # ₹ LTV above which = always needs Mukul approval
