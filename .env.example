# ─────────────────────────────────────────────
#  Hi-Tech AI Sales Org — Environment Config
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# App
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Database (SQLite default; use PostgreSQL URL on Railway)
DATABASE_URL=sqlite+aiosqlite:///./hitech_sales.db

# ── AI API (NVIDIA) ──────────────────────────
AI_API_KEY=nvapi-...
AI_MODEL=openai/gpt-oss-120b
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_PROVIDER=nvidia

# ── WhatsApp Meta Cloud API ──────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=EAAB...
WHATSAPP_VERIFY_TOKEN=hitech-verify-2026
WHATSAPP_API_VERSION=v20.0

# ── AiSensy WhatsApp API ─────────────────────
AISENSY_API_KEY=
AISENSY_USERNAME=Hi Tech Group 8161

# ── CRM (rustx.net) ─────────────────────────
CRM_BASE_URL=https://api-crm.rustx.net
CRM_TOKEN=
CRM_USERNAME=
CRM_PASSWORD=
CRM_POLL_INTERVAL_MINUTES=10080     # 7 days (auto-sync interval)
CRM_ADMIN_EMP_CODE=1494             # Nagender — admin with full data access (DO NOT CHANGE)

# ── Email / SMTP ─────────────────────────────
EMAIL_SMTP_HOST=smtp.hostinger.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=admin@hitechgroup.in
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=Mukul Sareen
EMAIL_FROM_ADDRESS=admin@hitechgroup.in

# ── Gmail API (optional — writing style) ────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback

# ── Owner ────────────────────────────────────
MUKUL_PHONE=919XXXXXXXXX
MUKUL_NAME=Mukul Sareen

# ── Escalation Rules ─────────────────────────
AI_CONFIDENCE_THRESHOLD=88
SENIOR_ESCALATION_WINDOW_HOURS=24
PRICING_AUTHORITY_PCT=8
KEY_ACCOUNT_LTV_THRESHOLD=2000000
